{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vijay-sachdeva.github.io/us-ai-infra/schemas/projects.schema.json",
  "title": "US AI data-center project ledger",
  "description": "Open, source-linked dataset of named US AI data-center campuses and their power deals. Code MIT, data CC BY 4.0 (analyst sources retain their own terms, marked per source).",
  "type": "object",
  "required": ["name", "version", "generated", "license", "records"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string", "description": "semver of the dataset" },
    "generated": { "type": "string", "description": "ISO date this build was generated" },
    "license": { "type": "string", "const": "CC-BY-4.0" },
    "schema": { "type": "string" },
    "attribution": { "type": "string" },
    "record_count": { "type": "integer" },
    "records": { "type": "array", "items": { "$ref": "#/$defs/project" } }
  },
  "$defs": {
    "project": {
      "type": "object",
      "required": ["id", "name", "operator", "state", "capacity_mw", "capacity_type", "status", "provenance", "transformation", "confidence", "sources", "revision"],
      "properties": {
        "id": { "type": "string", "description": "stable slug, e.g. hyperion-la" },
        "name": { "type": "string" },
        "operator": { "type": "string" },
        "state": { "type": "string", "description": "USPS 2-letter code" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": ["number", "null"] },
            "lon": { "type": ["number", "null"] },
            "precision": { "type": "string", "enum": ["site", "city", "county", "unknown"] }
          }
        },
        "capacity_mw": { "type": ["number", "null"] },
        "capacity_type": { "type": "string", "enum": ["total_power", "it_critical_load", "unspecified"], "description": "what the MW figure measures" },
        "status": { "type": "string", "enum": ["operational", "construction", "planned", "announced", "unknown"] },
        "status_as_of": { "type": "string", "description": "YYYY-MM the status was observed" },
        "power": {
          "type": "object",
          "properties": {
            "generation": { "type": "string" },
            "model": { "type": "string", "enum": ["BTM", "Colocated", "Grid"], "description": "behind-the-meter, colocated generation, or grid-supplied" }
          }
        },
        "note": { "type": "string" },
        "provenance": { "type": "string", "enum": ["government", "filing", "operator", "trade_press", "analyst", "unknown"], "description": "class of the primary source" },
        "transformation": { "type": "string", "enum": ["reported", "calculated", "estimated", "forecast", "scenario"], "description": "how the value relates to the source" },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "sources": { "type": "array", "items": { "$ref": "#/$defs/source" } },
        "revision": { "type": "integer", "description": "bumped when a field changes; see CHANGELOG" }
      }
    },
    "source": {
      "type": "object",
      "required": ["source_id", "url", "publisher", "provenance", "supports_claim"],
      "properties": {
        "source_id": { "type": "string" },
        "url": { "type": ["string", "null"], "description": "canonical public URL; null if no verifiable public source found" },
        "label": { "type": "string" },
        "publisher": { "type": "string" },
        "provenance": { "type": "string", "enum": ["government", "filing", "operator", "trade_press", "analyst", "unknown"] },
        "published": { "type": "string", "description": "YYYY-MM-DD or YYYY-MM of the source" },
        "retrieved": { "type": "string", "description": "ISO date the URL was last checked" },
        "supports_claim": { "type": "boolean", "description": "verified the page states this operator + ~MW + status" }
      }
    }
  }
}
